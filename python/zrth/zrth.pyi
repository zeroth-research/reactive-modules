from torch import Tensor as TorchTensor
from typing import override, Iterable


class IType:
    # Arithmetic
    @staticmethod
    def Add() -> IType: ...
    @staticmethod
    def Sub() -> IType: ...
    @staticmethod
    def Mul() -> IType: ...
    @staticmethod
    def Div() -> IType: ...
    @staticmethod
    def Mod() -> IType: ...
    @staticmethod
    def Neg() -> IType: ...
    @staticmethod
    def Abs() -> IType: ...
    @staticmethod
    def MatMul() -> IType: ...
    # Comparison
    @staticmethod
    def Eq() -> IType: ...
    @staticmethod
    def Neq() -> IType: ...
    @staticmethod
    def Lt() -> IType: ...
    @staticmethod
    def Le() -> IType: ...
    @staticmethod
    def Gt() -> IType: ...
    @staticmethod
    def Ge() -> IType: ...
    # Logical
    @staticmethod
    def And() -> IType: ...
    @staticmethod
    def Or() -> IType: ...
    @staticmethod
    def Not() -> IType: ...
    @staticmethod
    def Xor() -> IType: ...
    @staticmethod
    def Xnor() -> IType: ...
    @staticmethod
    def Implies() -> IType: ...
    # Control flow
    @staticmethod
    def Ite() -> IType: ...
    # Transcendental
    @staticmethod
    def Sin() -> IType: ...
    @staticmethod
    def Cos() -> IType: ...
    # Special
    @staticmethod
    def Id() -> IType: ...
    @staticmethod
    def Argmax() -> IType: ...
    @staticmethod
    def ReLU() -> IType: ...
    @staticmethod
    def Tanh() -> IType: ...
    @staticmethod
    def Linear() -> IType: ...
    # Tensor
    @staticmethod
    def TensorGet() -> IType: ...
    @staticmethod
    def TensorSet() -> IType: ...
    @staticmethod
    def TensorSum() -> IType: ...
    @staticmethod
    def TensorMean() -> IType: ...
    @staticmethod
    def TensorMax() -> IType: ...
    # Word-level
    @staticmethod
    def BitSelect(h: int, l: int) -> IType: ...
    @staticmethod
    def Extend(n: int) -> IType: ...
    @staticmethod
    def ToBool() -> IType: ...
    @staticmethod
    def ToWord1() -> IType: ...
    @staticmethod
    def ToUnsigned() -> IType: ...
    @staticmethod
    def ToSigned() -> IType: ...
    # Constants
    @staticmethod
    def Tensor(val: TorchTensor) -> IType: ...
    @staticmethod
    def ConstBool(val: bool) -> IType: ...
    @staticmethod
    def ConstInt(val: int) -> IType: ...
    @staticmethod
    def Uninterpreted(name: str) -> IType: ...

