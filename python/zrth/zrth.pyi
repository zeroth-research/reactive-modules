from torch import Tensor as TorchTensor
from typing import override, Iterable

class Wire:
    def __init__(self, id: int, dtype: DType) -> None: ...
    def id(self) -> int: ...
    def dtype(self) -> DType: ...
    @override
    def __str__(self) -> str: ...
    @override
    def __repr__(self) -> str: ...
    @override
    def __eq__(self, other: object) -> bool: ...
    @override
    def __hash__(self) -> int: ...

class DType:
    @staticmethod
    def TensorBool(shape: list[int]) -> DType: ...
    @staticmethod
    def TensorInt(shape: list[int]) -> DType: ...
    @staticmethod
    def TensorFloat(shape: list[int]) -> DType: ...
    @staticmethod
    def TensorReal(shape: list[int]) -> DType: ...
    @staticmethod
    def from_str(s: str) -> DType: ...
    def dims(self) -> list[int]: ...
    def eq_dtype(self, other: DType) -> bool: ...
    def reshape(self, shape: list[int]) -> DType: ...
    @override
    def __eq__(self, other: object) -> bool: ...
    @override
    def __str__(self) -> str: ...
    @override
    def __repr__(self) -> str: ...

    # defined in `zrth.__init__.py`
    Int: DType
    Float: DType
    Bool: DType
    Real: DType

class IType:
    @staticmethod
    def Add() -> IType: ...
    @staticmethod
    def Sub() -> IType: ...
    @staticmethod
    def Mul() -> IType: ...
    @staticmethod
    def Div() -> IType: ...
    @staticmethod
    def MatMul() -> IType: ...
    @staticmethod
    def Eq() -> IType: ...
    @staticmethod
    def Neq() -> IType: ...
    @staticmethod
    def Lt() -> IType: ...
    @staticmethod
    def Le() -> IType: ...
    @staticmethod
    def Gt() -> IType: ...
    @staticmethod
    def Ge() -> IType: ...
    @staticmethod
    def And() -> IType: ...
    @staticmethod
    def Or() -> IType: ...
    @staticmethod
    def Not() -> IType: ...
    @staticmethod
    def Ite() -> IType: ...
    @staticmethod
    def Id() -> IType: ...
    @staticmethod
    def Argmax() -> IType: ...
    @staticmethod
    def Tensor(val: TorchTensor) -> IType: ...
    @staticmethod
    def Input(name: str) -> IType: ...
    @staticmethod
    def Output(name: str) -> IType: ...

class Term:
    @staticmethod
    def function(itype: IType, write: list[Wire], read: list[Wire]) -> Term: ...
    @staticmethod
    def constant(itype: IType, write: list[Wire]) -> Term: ...
    def __init__(
        self, itype: IType, write: list[Wire], read: list[Wire] | None
    ) -> None: ...
    def write(self) -> Iterable[Wire]: ...
    def read(self) -> Iterable[Wire]: ...
    @override
    def __str__(self) -> str: ...
    @override
    def __repr__(self) -> str: ...

class RustContext:
    def fresh_wire_id(self) -> int: ...
    def tmp_wire(self, dtype: DType) -> Wire: ...
    def wire(self, name: str, dtype: DType) -> Wire: ...
    def __len__(self) -> int: ...

class Transition:
    def __init__(
        self,
        vars_in: list,
        vars_env: list,
        vars_env_new: list,
        vars_out: list,
        terms: list[Term],
    ): ...
    def intf_in(self) -> Iterable[Wire]: ...
    def intf_out(self) -> Iterable[Wire]: ...
    def intf_env(self) -> Iterable[Wire]: ...

class WiredTransitions:
    def __init__(self): ...
    def init(self, module, ctx: RustContext) -> None: ...
    def step(self, module, ctx: RustContext) -> None: ...
    def wire_transition(self, t: Transition, ctx: RustContext) -> None: ...
    def __add__(self, t: Transition) -> WiredTransitions: ...
    def __len__(self) -> int: ...
    def is_empty(self) -> bool: ...
    def to_html(self, ctx: RustContext, path: str) -> None: ...

class AtomTerm: ...
class Module: ...
